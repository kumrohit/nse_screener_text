# data stores (regenerate via backfill — never commit market data)
data/*.parquet
!data/.gitkeep
data/*.csv
data/*.jsonl
data/user_presets.json
data/config_local.toml
# per-universe stores (ROADMAP Item 15 Phase A: data/{universe_id}/…)
data/*/*.parquet
data/*/*.csv
data/*/*.jsonl
# indicator-panel cache sidecar (ROADMAP Item 20 P1) — .json, not .jsonl,
# so it needs its own line; the .parquet line above already covers the
# cache file itself
data/*/*.meta.json
# versioned evidence backups (ROADMAP Item 18 v1.0 hardening) — local
# only, rotated to 30; the off-machine copy is a manual step, not this
data/backups/

# python
__pycache__/
*.pyc
.pytest_cache/
*.egg-info/
build/
dist/
.venv/

# env / secrets
.env

# editor
.vscode/
.idea/

# macOS
.DS_Store
